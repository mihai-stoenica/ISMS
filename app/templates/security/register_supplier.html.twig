{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}

    <div class="flex flex-col items-center">
        <fieldset class="fieldset bg-base-200 border-base-300 rounded-box w-xs border p-4">
            <legend class="fieldset-legend">Register</legend>

            {%if not app.user%}
                {{ form_start(registrationForm) }}

                <div >
                    {{ form_label(registrationForm.user.name, null, {'label_attr': {'class': 'label'}}) }}
                    {{ form_widget(registrationForm.user.name, {'attr': {
                        'class': 'input w-full',
                        'placeholder': 'Name'
                    }}) }}

                    <div class="text-error text-sm mt-1">
                        {{ form_errors(registrationForm.user.name) }}
                    </div>
                </div>

                <div >
                    {{ form_label(registrationForm.user.email, null, {'label_attr': {'class': 'label'}}) }}
                    {{ form_widget(registrationForm.user.email, {'attr': {
                        'class': 'input w-full',
                        'placeholder': 'Email'
                    }}) }}

                    <div class="text-error text-sm mt-1">
                        {{ form_errors(registrationForm.user.email) }}
                    </div>
                </div>

                <div >
                    {{ form_widget(registrationForm.user.plainPassword) }}

                    <div class="text-error text-sm mt-1">
                        {{ form_errors(registrationForm.user.plainPassword) }}
                    </div>
                </div>


                <div >
                    {{ form_label(registrationForm.uniqueIdentifier, null, {'label_attr': {'class': 'label'}}) }}
                    {{ form_widget(registrationForm.uniqueIdentifier, {'attr': {
                        'class': 'input w-full',
                        'placeholder': 'Unique Identifier Code'
                    }}) }}

                    <div class="text-error text-sm mt-1">
                        {{ form_errors(registrationForm.uniqueIdentifier) }}
                    </div>
                </div>

                <div >
                    {{ form_label(registrationForm.phoneNumber, null, {'label_attr': {'class': 'label'}}) }}
                    {{ form_widget(registrationForm.phoneNumber, {'attr': {
                        'class': 'input w-full',
                        'placeholder': 'Phone Number'
                    }}) }}

                    <div class="text-error text-sm mt-1">
                        {{ form_errors(registrationForm.phoneNumber) }}
                    </div>
                </div>

                <div>
                    {{ form_label(registrationForm.address, null, {'label_attr': {'class': 'label'}}) }}
                    {{ form_widget(registrationForm.address, {'attr': {
                        'class': 'input w-full',
                        'placeholder': 'Address'
                    }}) }}

                    <div class="text-error text-sm mt-1">
                        {{ form_errors(registrationForm.phoneNumber) }}
                    </div>
                </div>

                {% if registrationForm.vars.errors|length > 0 %}
                    <div class="text-error mb-4">
                        {{ form_errors(registrationForm) }}
                    </div>
                {% endif %}

                <div class="flex flex-row items-center mt-4 justify-between">
                    <button type="submit" class="btn btn-neutral mt-4">Register</button>
                    <span>Already have an account? <a href="/login"
                                                      class="underline">Login</a></span>
                </div>


                {{ form_end(registrationForm) }}

            {% else %}

                <div class="mb-3">
                    You are logged in as {{ app.user.userIdentifier }} <a
                        href="{{ path('app_logout') }}" class="underline">Logout</a>
                </div>
            {% endif %}

        </fieldset>

    </div>

{% endblock %}
