{% extends 'base.html.twig' %}

{% block title %}Your Cart{% endblock %}

{% block body %}
    <div class="p-10 max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold mb-6">Review Your Order</h1>

        {% if items is empty %}
            <div class="alert alert-info">
                <span>Your cart is empty. <a href="{{ path('app_products_catalog') }}" class="link">Go back to catalog</a></span>
            </div>
        {% else %}
            <div class="overflow-x-auto bg-base-100 rounded-box shadow">
                <table class="table">
                    <thead>
                    <tr>
                        <th>Product</th>
                        <th>Quantity</th>
                        <th>Subtotal</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for item in items %}
                        <tr>
                            <td>{{ item.product.name }}</td>
                            <td>{{ item.quantity }}</td>
                            <td class="font-mono">${{ item.subtotal|number_format(2) }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                    <tfoot>
                    <tr class="text-lg font-bold">
                        <td colspan="2" class="text-right">Total:</td>
                        <td class="text-success">${{ total|number_format(2) }}</td>
                    </tr>
                    </tfoot>
                </table>
            </div>

            <div class="mt-8 flex justify-between items-center">
                <a href="{{ path('app_products_catalog') }}" class="btn btn-ghost">Continue Shopping</a>

                <form action="{{ path('app_cart_checkout') }}" method="POST">
                    <button type="submit" class="btn btn-success px-10">
                        Place Order
                    </button>
                </form>
            </div>
        {% endif %}
    </div>
{% endblock %}
