{% extends 'base.html.twig' %}

{% block title %}Buy {{ product.name }}{% endblock %}

{% block body %}
    <div class="p-6">
        <h1 class="text-2xl font-bold mb-4">Suppliers for {{ product.name }}</h1>

        <div class="overflow-x-auto border rounded-box border-base-300 shadow-sm bg-base-100">
            <table class="table table-zebra w-full">
                <thead>
                <tr>
                    <th>Supplier Name</th>
                    <th>Email</th>
                    <th>Price</th>
                    <th class="text-center">Action</th>
                </tr>
                </thead>
                <tbody>
                {% for sp in sellers %}
                    <tr>
                        <td>
                            <div class="font-bold">{{ sp.supplier.user.name }}</div>
                        </td>
                        <td>{{ sp.supplier.user.email }}</td>
                        <td class="text-success font-mono font-bold">
                            ${{ sp.purchasePrice|number_format(2) }}
                        </td>
                        <td class="text-center">
                            <form action="{{ path("app_contract_buy", {"supplierId": sp.supplier.id, "productId": sp.product.id}) }}" method="POST" class="flex justify-center">
                                <div class="join">
                                    <select name="delivery_ramp" class="select select-bordered select-sm join-item focus:outline-primary" required>
                                        <option disabled selected value="">Select Ramp</option>
                                        {% for ramp in ramps %}
                                            <option value="{{ ramp.value }}">Ramp {{ ramp.value }}</option>
                                        {% endfor %}
                                    </select>

                                    <input
                                        name="quantity"
                                        type="number"
                                        step="1"
                                        min="1"
                                        max="99999"
                                        placeholder="Quantity"
                                        class="input input-bordered input-sm join-item w-24 focus:outline-primary"
                                        required
                                    />

                                    <button type="submit" class="btn btn-sm btn-success join-item">
                                        Buy
                                    </button>
                                </div>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center italic py-10">No suppliers found for this product.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="mt-4">
            <a href="{{ path('app_products_catalog') }}" class="btn btn-ghost">← Back to Catalog</a>
        </div>
    </div>
{% endblock %}
