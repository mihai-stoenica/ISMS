{% extends 'base.html.twig' %}

{% block title %}My Profile{% endblock %}

{% block body %}
    <div class="min-h-[85vh] flex items-center justify-center py-10 px-4 font-sans">

        <div class="w-full max-w-md bg-white dark:bg-slate-800 rounded-[2rem] shadow-[0_8px_30px_rgb(0,0,0,0.08)] dark:shadow-[0_8px_30px_rgb(0,0,0,0.4)] border border-transparent dark:border-slate-700 p-8 transition-colors duration-200">

            <div class="text-center mb-8">
                <h1 class="text-2xl text-slate-900 dark:text-white mb-2 font-extrabold tracking-tight">User Profile</h1>
                <div class="inline-block bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 px-4 py-1 rounded-full text-[11px] font-bold uppercase tracking-wider">
                    {{ user_data.roles[0] | replace({'ROLE_': ''}) }}
                </div>
            </div>

            <form action="{{ path('app_profile_edit') }}" method="POST" class="space-y-6">

                <div class="space-y-4">
                    <h3 class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider border-b border-slate-100 dark:border-slate-700 pb-2">Basic Details</h3>

                    <div>
                        <label for="name" class="block text-xs font-semibold text-slate-600 dark:text-slate-300 mb-1 pl-1">Full Name</label>
                        <input type="text" id="name" name="name" value="{{ user_data.name }}" required
                               class="w-full px-4 py-2.5 bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-600 rounded-2xl text-sm text-slate-800 dark:text-white transition-all focus:bg-white dark:focus:bg-slate-900 focus:ring-2 focus:ring-blue-400 focus:border-transparent outline-none">
                    </div>

                    <div>
                        <label for="email" class="block text-xs font-semibold text-slate-600 dark:text-slate-300 mb-1 pl-1">Email Address</label>
                        <input type="email" id="email" name="email" value="{{ user_data.email }}" required
                               class="w-full px-4 py-2.5 bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-600 rounded-2xl text-sm text-slate-800 dark:text-white transition-all focus:bg-white dark:focus:bg-slate-900 focus:ring-2 focus:ring-blue-400 focus:border-transparent outline-none">
                    </div>
                </div>

                {% if 'ROLE_SUPPLIER' in user_data.roles and user_data.supplierProfile is not null %}
                    <div class="space-y-4 pt-2">
                        <h3 class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider border-b border-slate-100 dark:border-slate-700 pb-2">Supplier Details</h3>

                        <div>
                            <label for="unique_identifier" class="block text-xs font-semibold text-slate-600 dark:text-slate-300 mb-1 pl-1">CUI (Read-Only)</label>
                            <input type="text" id="unique_identifier" name="unique_identifier" value="{{ user_data.supplierProfile.uniqueIdentifier }}" readonly
                                   class="w-full px-4 py-2.5 bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl text-sm text-slate-500 dark:text-slate-400 cursor-not-allowed outline-none">
                        </div>

                        <div>
                            <label for="phone_number" class="block text-xs font-semibold text-slate-600 dark:text-slate-300 mb-1 pl-1">Phone Number</label>
                            <input type="text" id="phone_number" name="phone_number" value="{{ user_data.supplierProfile.phoneNumber }}" required
                                   class="w-full px-4 py-2.5 bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-600 rounded-2xl text-sm text-slate-800 dark:text-white transition-all focus:bg-white dark:focus:bg-slate-900 focus:ring-2 focus:ring-blue-400 focus:border-transparent outline-none">
                        </div>

                        <div>
                            <label for="address" class="block text-xs font-semibold text-slate-600 dark:text-slate-300 mb-1 pl-1">Address</label>
                            <input type="text" id="address" name="address" value="{{ user_data.supplierProfile.address }}" required
                                   class="w-full px-4 py-2.5 bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-600 rounded-2xl text-sm text-slate-800 dark:text-white transition-all focus:bg-white dark:focus:bg-slate-900 focus:ring-2 focus:ring-blue-400 focus:border-transparent outline-none">
                        </div>
                    </div>
                {% endif %}

                <div class="pt-4">
                    <button type="submit" class="w-full py-3 bg-slate-900 dark:bg-blue-600 hover:bg-black dark:hover:bg-blue-500 text-white rounded-2xl text-sm font-bold transition-all active:scale-95 shadow-md">
                        Save Profile Changes
                    </button>
                </div>

            </form>
        </div>
    </div>
{% endblock %}
