{% extends 'base.html.twig' %}

{% block title %}Analytics{% endblock %}

{% block body %}
    <div class="flex h-screen bg-base-200 overflow-hidden">
        <aside class="w-64 bg-base-100 border-r p-4 space-y-4">
            <h2 class="text-xl font-bold">Analytics Hub</h2>
            <nav class="flex flex-col gap-2">
                <a href="{{ path('app_analytics', {type: 'occupation'}) }}"
                   class="btn {{ currentType == 'occupation' ? 'btn-primary' : 'btn-ghost' }} justify-start">
                    Occupation level
                </a>
                <a href="{{ path('app_analytics', {type: 'financial'}) }}"
                   class="btn {{ currentType == 'financial' ? 'btn-primary' : 'btn-ghost' }} justify-start">
                    Financial
                </a>
                <a href="{{ path('app_analytics', {type: 'suppliers'}) }}"
                   class="btn {{ currentType == 'suppliers' ? 'btn-primary' : 'btn-ghost' }} justify-start">
                    Suppliers
                </a>
            </nav>
        </aside>

        <main class="flex-1 p-8 overflow-y-auto">

            <form method="GET" action="{{ path('app_analytics', {type: currentType}) }}" class="bg-base-100 p-4 rounded-box shadow mb-8 flex gap-4 items-end">
                {% if currentType != 'occupation' %}
                <div class="form-control">
                    <label class="label"><span class="label-text">View By</span></label>
                    <select name="range" class="select select-bordered select-sm">
                        <option value="day" {{ currentRange == 'day' ? 'selected' }}>Daily</option>
                        <option value="month" {{ currentRange == 'month' ? 'selected' }}>Monthly</option>
                    </select>
                </div>
                <div class="form-control">
                    <label class="label"><span class="label-text">Start Date</span></label>
                    <input type="date" name="start" value="{{ app.request.query.get('start') }}" class="input input-bordered input-sm">
                </div>
                <div class="form-control">
                    <label class="label"><span class="label-text">End Date</span></label>
                    <input type="date" name="end" value="{{ app.request.query.get('end') }}" class="input input-bordered input-sm">
                </div>
                <button type="submit" class="btn btn-success btn-sm">Update Analytics</button>
                {% endif %}
                <a href="{{ path('app_analytics_export', {
                    type: currentType,
                    range: app.request.query.get('range'),
                    start: app.request.query.get('start'),
                    end: app.request.query.get('end')
                }) }}" class="btn btn-success btn-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                    Export CSV
                </a>
            </form>


            <div class="grid grid-cols-1 gap-6">
                {% if currentType == 'occupation' and extraData is not empty %}
                    <div class="stats shadow w-full mb-8">
                        <div class="stat">
                            <div class="stat-title">Current Occupancy</div>
                            <div class="stat-value text-primary">{{ extraData.percent }}%</div>
                            <div class="stat-desc">Based on {{ extraData.total }} total slots</div>
                        </div>
                    </div>
                {% endif %}

                <div class="card bg-base-100 shadow-xl p-6 mb-20">
                    <div class="h-120">
                        {{ render_chart(chart) }}
                    </div>
                </div>
            </div>
        </main>
    </div>
{% endblock %}
