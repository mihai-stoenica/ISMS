{% extends 'base.html.twig' %}

{% block title %}Warehouse Stocks{% endblock %}

{% block body %}
    <div class="flex h-full bg-base-100 overflow-hidden">
        <aside class="w-64 border-r border-base-300 p-4 space-y-4 overflow-y-auto flex-shrink-0">
            <h2 class="text-xl font-bold mb-4">Stock Filters</h2>
            <form method="GET">
                <div>
                    <label class="label font-bold">Search</label>
                    <input type="text" name="search" placeholder="Search product..." class="input input-bordered w-full" value="{{ app.request.query.get('search') }}" />

                    <label class="label font-bold">Category</label>
                    <select name="categoryId" class="select select-bordered w-full">
                        <option value="">All Categories</option>
                        {% for category in categories %}
                            <option value="{{ category.id }}"
                                    {% if app.request.query.get('categoryId') == category.id %}selected{% endif %}>
                                {{ category.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <button class="btn btn-success w-full mt-4">Apply Filters</button>
                <a href="{{ path('app_stock_index') }}" class="btn btn-error w-full mt-4">Reset All</a>
            </form>
        </aside>

        <main class="flex-1 p-6 flex flex-col items-center overflow-y-auto">

            <div class="w-full max-w-5xl mb-6 flex justify-between items-center">
                <h1 class="text-3xl font-bold">Warehouse Inventory</h1>

                <a href="{{ path('app_stock_export') }}" class="btn btn-outline btn-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                    Export CSV
                </a>
            </div>

            <div class="w-full max-w-5xl">
                <div class="overflow-x-auto border rounded-box border-base-300 shadow-sm bg-base-100">
                    <table class="table table-zebra w-full">
                        <thead class="bg-base-200">
                        <tr>
                            <th class="text-lg text-center">Product Name</th>
                            <th class="text-lg text-center">Location</th>
                            <th class="text-lg text-center">Current Stock</th>
                            <th class="text-lg text-center">Alert Limit</th>

                            {% if is_granted('ROLE_MANAGER') %}
                                <th class="text-lg text-center">Actions</th>
                            {% endif %}
                        </tr>
                        </thead>
                        <tbody>
                        {% for product in products %}
                            {% set isLowStock = (product.currentStock|default(0)) <= product.lowStockThreshold %}

                            <tr class="{{ isLowStock ? 'bg-error/10' : '' }}">
                                <td class="text-center">
                                    <div class="font-bold">{{ product.name }}</div>
                                    <div class="text-sm opacity-50">{{ product.category ? product.category.name : 'Uncategorized' }}</div>
                                </td>
                                <td class="text-center">
                                    <span class="badge badge-ghost">{{ product.location ? product.location.value : 'Unassigned' }}</span>
                                </td>
                                <td class="text-center">
                                    <div class="font-mono text-lg font-bold {{ isLowStock ? 'text-error' : 'text-success' }}">
                                        {{ product.currentStock|default(0) }}
                                    </div>
                                    {% if isLowStock %}
                                        <span class="badge badge-error badge-sm mt-1">Action Needed</span>
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    {% if is_granted('ROLE_MANAGER') %}
                                        <form action="{{ path('app_stock_update_threshold', {'id': product.id}) }}" method="POST" class="flex justify-center">
                                            <div class="join">
                                                <input
                                                    type="number"
                                                    name="threshold"
                                                    value="{{ product.lowStockThreshold }}"
                                                    min="0"
                                                    class="input input-sm input-bordered join-item w-20 focus:outline-primary"
                                                />
                                                <button type="submit" class="btn btn-sm btn-neutral join-item">Set</button>
                                            </div>
                                        </form>
                                    {% else %}
                                        <span class="font-mono text-lg text-gray-500 font-semibold">
                                            {{ product.lowStockThreshold }}
                                        </span>
                                    {% endif %}
                                </td>

                                {% if is_granted('ROLE_MANAGER') %}
                                    <td class="text-center">
                                        <a href="{{ path('app_products_catalog', {'search': product.name}) }}" class="btn btn-sm btn-primary">
                                            Restock
                                        </a>
                                    </td>
                                {% endif %}
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="{{ is_granted('ROLE_MANAGER') ? 5 : 4 }}" class="text-center italic text-gray-500 py-10">
                                    No products found matching filters.
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>

                    <div class="flex justify-center py-4 bg-base-100">
                        <div class="join">
                            {{ knp_pagination_render(products) }}
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
{% endblock %}
