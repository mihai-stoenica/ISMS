{% extends 'base.html.twig' %}

{% block title %}Contracts Management{% endblock %}

{% block body %}
    <div class="overflow-x-auto">
        <table class="table table-zebra">
            <thead>
            <tr>
                <th>Date</th>
                <th>Product</th>
                <th>Quantity</th>
                <th>Total Cost</th>
                <th>Requested By (Manager)</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for contract in contracts %}
                <tr>
                    <td>
                        {{ contract.date ? contract.date|date('Y-m-d H:i') : 'N/A' }}
                    </td>
                    <td>
                        <div class="font-bold">{{ contract.product.name }}</div>
                    </td>
                    <td>{{ contract.quantity }}</td>
                    <td class="text-success font-mono font-bold">
                        ${{ contract.totalCost|number_format(2) }}
                    </td>
                    <td>
                        <div>{{ contract.manager.name }}</div>
                        <div class="text-xs opacity-50">{{ contract.manager.email }}</div>
                    </td>
                    <td>
                        <span class="badge {{ contract.status.name == 'PENDING' ? 'badge-warning' : (contract.status.name == 'DONE' ? 'badge-success' : 'badge-error') }}">
                            {{ contract.status.name }}
                        </span>
                    </td>
                    <td>
                        {% if is_granted('ROLE_SUPPLIER') and contract.status.name == 'PENDING' %}
                            <div class="flex gap-2">
                                <form action="{{ path('app_contract_accept', {'id': contract.id}) }}" method="POST">
                                    <button type="submit" class="btn btn-sm btn-success">
                                        Accept
                                    </button>
                                </form>

                                <form action="{{ path('app_contract_reject', {'id': contract.id}) }}" method="POST">
                                    <button type="submit" class="btn btn-sm btn-error">
                                        Reject
                                    </button>
                                </form>
                            </div>
                        {% elseif contract.status.name == 'ACCEPTED' %}
                            <span class="text-sm text-green-600 font-bold flex items-center gap-1">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                                Done (Accepted)
                            </span>
                        {% elseif contract.status.name == 'REJECTED' %}
                            <span class="text-sm text-red-600 font-bold flex items-center gap-1">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                                Rejected
                            </span>
                        {% else %}
                            <span class="text-sm text-gray-500 italic">Waiting for supplier...</span>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="text-center italic">No contracts found.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
